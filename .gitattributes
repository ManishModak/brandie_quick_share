# Handle line endings automatically for files detected as text
# and normalize them to LF in the repo.
* text=auto

# Force source code and configuration files to use LF line endings
*.dart text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.plist text eol=lf
*.pbxproj text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sh text eol=lf

# Force Windows-specific batch scripts to use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Denote binary files to prevent Git from modifying their line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.pdf binary
